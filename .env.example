# Copy this file to .env and fill values locally.
# Recommended: run `npm run privacy -- init` to generate a local .env with a random
# PX402_NOTE_PASSWORD, then fill only the disposable wallet private key locally.
# Never commit .env. Never paste private keys or note passwords into chat.

# Disposable low-value Base wallet private key.
# The CLI accepts a single 32-byte hex key with or without 0x.
# Do not use a main wallet, mnemonic phrase, seed phrase, or JSON keystore.
# Address-only funding can receive assets, but real spend requires this local signer.
PRIVATE_KEY=

# Base mainnet only for this hackathon product.
X402_CHAIN=base
BASE_RPC_URL=https://mainnet.base.org

# Local encrypted px402 note storage.
# This is NOT your wallet private key. It encrypts local data/notes and data/recovery files.
# Use a new random password, record it in your own password manager, and keep it local.
# Must be at least 12 characters and must not be the old public demo default.
# PowerShell generator:
# [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(24))
PX402_NOTE_PASSWORD=
NOTE_DIR=./data/notes
RECEIPT_DIR=./data/receipts
RESPONSE_DIR=./data/responses
RECOVERY_DIR=./data/recovery

# PRXVT SDK currently downloads remote wasm/zkey files without local hash pinning.
# Leave empty for no-spend review and dry-runs.
# For hackathon-only real spend, set exactly:
# PRXVT_REMOTE_CIRCUITS_ACK=I_UNDERSTAND_UNPINNED_REMOTE_CIRCUITS
PRXVT_REMOTE_CIRCUITS_ACK=

# Spend policy.
MAX_USD_PER_CALL=0.02
MONTHLY_BUDGET_USD=20
# Deposit/payment timing privacy.
# Real paid calls use an existing note by default. Prepare first, wait, then pay.
MIN_NOTE_AGE_MINUTES=60
AUTO_PREPARE_BEFORE_PAYMENT=false
# Optional amount normalization. 0 means exact burner funding. Example privacy bucket: 0.1.
BURNER_FUNDING_BUCKET_USD=0
MIN_BASE_ETH_BUFFER=0.00005

# 0x Gasless onboarding.
# Required if the disposable wallet has Base USDC but too little native Base ETH for px402 deposit gas.
0X_API_KEY=
ZEROX_API_KEY=
ZEROX_CHAIN_ID=8453
ZEROX_DUST_USDC=0.1

# Trade research demo defaults.
CMC_SYMBOL=ETH
EXA_QUERY=Ethereum market structure and Base ecosystem catalyst
EXA_NUM_RESULTS=3

# Existing weather smoke test.
X402_WEATHER_URL=https://httpay.xyz/api/weather?lat=22.3193&lon=114.1694

# Curvy/crops privacy adapter experiments are retained for research only.
CURVY_ENV=testnet
