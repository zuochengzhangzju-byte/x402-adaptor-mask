{
  "chains": ["ethereum", "solana"],
  "filters": {
    "include_smart_money_labels": ["Fund", "Smart Trader"],
    "exclude_smart_money_labels": ["30D Smart Trader"],
    "include_stablecoins": false,
    "include_native_tokens": false,
    "token_age_days": {
      "max": 30
    },
    "value_usd": {
      "min": 1000,
      "max": 100000
    },
    "balance_24h_percent_change": {
      "min": -0.1,
      "max": 0.1
    }
  },
  "order_by": [
    {
      "field": "value_usd",
      "direction": "DESC"
    }
  ],
  "pagination": {
    "page": 1,
    "per_page": 10
  }
}
